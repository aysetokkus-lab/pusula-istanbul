            J["📡 Saha Durumu\n(Supabase Realtime)"]
            K["📍 Güncel Durum"]
            K --> K1["🚢 Galataport\n20 gemi takvimi"]
            K --> K2["🕌 Sultanahmet\ndinamik namaz saatleri"]
