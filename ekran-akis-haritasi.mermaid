            K --> K4["🚇 Marmaray"]
            K --> K5["🚧 Yol Durumu"]
        end

        subgraph T2["🏛 Müzeler · muzeler.tsx · 391 LOC"]
            L["3 Kategori · 32 Mekan"]
            L --> L1["👑 Milli Saraylar (6)"]
            L --> L2["🏛 Müzeler (17)"]
            L --> L3["🎨 Özel Müzeler (9)"]
        end

        subgraph T3["🛥 Boğaz · bogaz.tsx · 344 LOC"]
            M["3 Vapur Şirketi"]
            M --> M1["🔴 Turyol\nsaatlik sefer"]
            M --> M2["🔵 Dentur Avrasya\n11 sefer"]
            M --> M3["🟡 Şehir Hatları\nkısa + uzun tur"]
