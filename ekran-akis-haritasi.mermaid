        end

        subgraph T6["🚨 Acil · acil.tsx · 161 LOC"]
            P["🆘 Acil Numaralar (5)"]
            Q["🪪 Meslek Kuruluşları (2)"]
            R["🔗 Faydalı Linkler (3)"]
            S["👤 Hesap\nGiriş/Çıkış"]
        end
    end

    subgraph MODALS["📋 Modal Ekranlar (9 adet)"]
        K1 -->|tıkla| MA["Gemi Takvimi\n10 yaklaşan gemi"]
        K2 -->|tıkla| MB["Sultanahmet Detay\nziyaret pencereleri + kurallar"]
        K3 -->|tıkla| MC["Ayasofya Detay\nmevsim + fiyat + kurallar"]
        L  -->|kart tıkla| MD["Mekan Detay\nsaat + fiyat + özel bilgi"]
        M1 -->|tıkla| ME["Turyol Tüm Saatler"]
        M2 -->|tıkla| MF["Dentur Tüm Saatler"]
        N  -->|durak tıkla| MG["Durak Tüm Saatler"]
        J  -->|Tümünü Gör| MH["Tüm Saha Bildirimleri\nkategori bazlı"]
        J  -->|＋ Bildir| MI["Durum Bildir\n3 adımlı wizard"]
    end

    subgraph DATA["💾 Veri Kaynakları"]
        API1["☁️ aladhan.com\nNamaz Vakitleri API"]
        DB1["🗄 Supabase\nauth.users\nprofiles\nsaha_noktalari\ncanli_durum"]
