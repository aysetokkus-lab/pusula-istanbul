        B -->|Hayır| C["giris.tsx\n🗺 İstanbul Rehber"]
        C --> D["Giriş Yap\n(email + şifre)"]
        C --> E["Kayıt Ol\n(isim + soyisim + email + şifre)"]
        C --> F["Misafir olarak devam et →"]
        D -->|Başarılı| TABS
        E -->|Başarılı| G["✅ E-posta doğrulama"]
        F -->|Session yok| TABS
    end

    subgraph TABS["📱 Tab Navigation (6 Sekme)"]
        direction TB

        subgraph T1["🏠 Ana Sayfa · index.tsx · 455 LOC"]
            H["⏰ Saat + Tarih\n(1sn güncelleme)"]
